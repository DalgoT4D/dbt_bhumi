# https://docs.sqlfluff.com/en/stable/configuration.html#default-configuration

[sqlfluff]
# Supported dialects https://docs.sqlfluff.com/en/stable/dialects.html
# Or run 'sqlfluff dialects'
dialect = postgres
templater = jinja

# Note: dbt templater disabled due to Python 3.14 compatibility issues
# To use dbt templater, upgrade to Python 3.12 or 3.13
# templater = dbt

# Comma separated list of rules to exclude, or None
exclude_rules = L001,L029,RF05, LT05, ST06, RF02, ST10
#max_line_length = 120